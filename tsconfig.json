{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    /* ---------------------------------------- */
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "src/**/*", 
    "artifacts/**/*.ts", 
    "artifacts/**/*.tsx",
    "termis_project_api/**/*.ts"
  ], 
  "exclude": ["node_modules", "dist"]
}