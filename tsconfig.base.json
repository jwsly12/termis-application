{
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "es2022",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"]
    // REMOVA: "customConditions": ["workspace"]
  }
}